  "components": {
    "schemas": {
      "BudgetRange": {
        "properties": {
          "min": {
            "type": "number",
            "title": "Min"
          },
          "max": {
            "type": "number",
            "title": "Max"
          }
        },
        "type": "object",
        "required": [
          "min",
          "max"
        ],
        "title": "BudgetRange"
      },
      "ClientRequest": {
        "properties": {
          "project_id": {
            "type": "string",
            "title": "Project Id"
          },
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "required_skills": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Required Skills"
          },
          "budget_range": {
            "$ref": "#/components/schemas/BudgetRange"
          },
          "deadline": {
            "type": "string",
            "format": "date-time",
            "title": "Deadline"
          },
          "project_type": {
            "$ref": "#/components/schemas/ProjectType"
          },
          "status": {
            "$ref": "#/components/schemas/ProjectStatus",
            "default": "Open"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "client_id",
          "title",
          "description",
          "required_skills",
          "budget_range",
          "deadline",
          "project_type"
        ],
        "title": "ClientRequest"
      },
      "ClientReview": {
        "properties": {
          "freelancer_id": {
            "type": "string",
            "title": "Freelancer Id"
          },
          "client_id": {
            "type": "string",
            "title": "Client Id"
          },
          "stars": {
            "type": "integer",
            "maximum": 5.0,
            "minimum": 1.0,
            "title": "Stars",
            "description": "Rating from 1 to 5"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "freelancer_id",
          "client_id",
          "stars",
          "description"
        ],
        "title": "ClientReview",
        "description": "Standalone schema for a review. Notice it links via freelancer_id."
      },
      "Education": {
        "properties": {
          "institution": {
            "type": "string",
            "title": "Institution"
          },
          "degree": {
            "type": "string",
            "title": "Degree"
          },
          "start_year": {
            "type": "integer",
            "title": "Start Year"
          },
          "end_year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Year"
          }
        },
        "type": "object",
        "required": [
          "institution",
          "degree",
          "start_year"
        ],
        "title": "Education"
      },
      "EvaluateTestPayload": {
        "properties": {
          "questions": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Questions"
          },
          "user_answers": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "User Answers"
          }
        },
        "type": "object",
        "required": [
          "questions",
          "user_answers"
        ],
        "title": "EvaluateTestPayload"
      },
      "EvaluationPayload": {
        "properties": {
          "proposal": {
            "additionalProperties": true,
            "type": "object",
            "title": "Proposal"
          },
          "project": {
            "additionalProperties": true,
            "type": "object",
            "title": "Project"
          }
        },
        "type": "object",
        "required": [
          "proposal",
          "project"
        ],
        "title": "EvaluationPayload"
      },
      "FreelancerPortfolio": {
        "properties": {
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "bio": {
            "type": "string",
            "title": "Bio"
          },
          "skills": {
            "items": {
